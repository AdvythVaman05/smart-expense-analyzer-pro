# Frontend environment variables
# Copy this file to .env.local for local development, or set in Vercel dashboard for production

# In development (Vite proxy handles routing — leave empty)
VITE_API_URL= https://smart-expense-analyzer-pro.onrender.com

# In production, set this to your deployed Render backend URL:
# VITE_API_URL=https://smart-expense-analyzer-api.onrender.com
