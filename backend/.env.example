# Backend environment variables
# Copy this file to .env and fill in real values for production deployment

# REQUIRED: Generate a strong secret key (e.g., `python -c "import secrets; print(secrets.token_hex(32))"`)
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string

# SQLite (development default)
DATABASE_URL=sqlite:///expense_analyzer.db

# PostgreSQL (optional — swap for production on Render)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Flask
FLASK_ENV=production
FLASK_DEBUG=0
